rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Comprobantes de ingresos y gastos — Editor/Admin puede escribir, público puede leer
    match /comprobantes/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Fotos de perfil — solo el propio usuario puede escribir
    match /perfiles/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Resúmenes bancarios — autenticados pueden leer, solo autenticados escribir
    match /resumenes_bancarios/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
