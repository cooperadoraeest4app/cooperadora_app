rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function estaAutenticado() {
      return request.auth != null;
    }

    function obtenerRol() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol;
    }

    function usuarioExiste() {
      return exists(/databases/$(database)/documents/usuarios/$(request.auth.uid));
    }

    function esAdmin() {
      return estaAutenticado() && usuarioExiste() && obtenerRol() == 'admin';
    }

    function esEditor() {
      return estaAutenticado() && usuarioExiste() && (obtenerRol() == 'editor' || obtenerRol() == 'admin');
    }

    function esAuditor() {
      return estaAutenticado() && usuarioExiste() && (obtenerRol() == 'auditor' || obtenerRol() == 'admin');
    }

    function estaActivo() {
      return usuarioExiste() && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.activo == true;
    }

    // COLECCIONES PÚBLICAS (lectura sin autenticación)
    match /configuracion/{doc} {
      allow read: if true;
      allow write: if esAdmin();
    }

    match /categorias/{doc} {
      allow read: if true;
      allow write: if esAdmin();
    }

    match /tipos_proyecto/{doc} {
      allow read: if true;
      allow write: if esAdmin();
    }

    match /metodos_pago/{doc} {
      allow read: if true;
      allow write: if esAdmin();
    }

    match /cuenta_bancaria/{cuentaId} {
      allow read: if true;
      allow write: if (esAdmin() || esEditor()) && estaActivo();
    }

    match /cuenta_bancaria/{cuentaId}/movimientos/{movId} {
      allow read: if true;
      allow write: if (esAdmin() || esEditor()) && estaActivo();
    }

    match /movimientos_bancarios/{doc} {
      allow read: if true;
      allow write: if esAdmin();
    }

    match /proyectos/{doc} {
      allow read: if true;
      allow write: if esEditor() && estaActivo();
    }

    match /items_proyecto/{doc} {
      allow read: if true;
      allow write: if esEditor() && estaActivo();
    }

    match /presupuestos_proyecto/{doc} {
      allow read: if true;
      allow write: if esEditor() && estaActivo();
    }

    match /ingresos/{doc} {
      allow read: if true;
      allow write: if esEditor() && estaActivo();
    }

    match /gastos/{doc} {
      allow read: if true;
      allow write: if esEditor() && estaActivo();
    }

    match /frecuencias_recurrencia/{doc} {
      allow read: if true;
      allow write: if esAdmin();
    }

    // COLECCIONES SOLO AUTENTICADOS
    match /usuarios/{userId} {
      allow read: if estaAutenticado();
      allow write: if esAdmin() || (estaAutenticado() && request.auth.uid == userId);
    }

    match /personas/{doc} {
      allow read: if estaAutenticado();
      allow create: if estaAutenticado();
      allow update, delete: if esEditor() && estaActivo();
    }

    match /socios/{doc} {
      allow read: if estaAutenticado();
      allow write: if esEditor() && estaActivo();
    }

    match /cuotas/{doc} {
      allow read: if estaAutenticado();
      allow write: if esEditor() && estaActivo();
    }

    match /pagos_cuota/{doc} {
      allow read: if estaAutenticado();
      allow write: if (esAdmin() || esEditor()) && estaActivo();
    }

    match /tarifas_cuota/{doc} {
      allow read: if true;
      allow write: if (esAdmin() || esEditor()) && estaActivo();
    }

    match /tipos_cuota/{doc} {
      allow read: if true;
      allow write: if esAdmin() && estaActivo();
    }

    match /invitaciones/{doc} {
      allow read: if true;
      allow create, delete: if esAdmin() || esEditor();
      allow update: if esAdmin() || esEditor() || estaAutenticado();
    }

    match /log_cambios/{doc} {
      allow read: if esAuditor();
      allow write: if estaAutenticado();
    }

    match /tipos_socio/{doc} {
      allow read: if estaAutenticado();
      allow write: if esAdmin();
    }

    match /subtipos_socio/{doc} {
      allow read: if estaAutenticado();
      allow write: if esAdmin();
    }

    match /cursos/{doc} {
      allow read: if true;
      allow write: if esAdmin() && estaActivo();
    }

    match /proveedores/{doc} {
      allow read: if estaAutenticado();
      allow write: if esEditor() && estaActivo();
    }

    match /presupuestos_proveedor/{doc} {
      allow read: if estaAutenticado();
      allow write: if esEditor() && estaActivo();
    }

    match /inventario/{doc} {
      allow read: if true;
      allow write: if esEditor() && estaActivo();
    }

    match /cargos/{doc} {
      allow read: if true;
      allow write: if esAdmin();
    }

    match /rubros/{doc} {
      allow read: if true;
      allow write: if esAdmin();
    }

    match /balance_snapshots/{doc} {
      allow read: if estaAutenticado();
      allow write: if esEditor() && estaActivo();
    }

    match /votaciones/{doc} {
      allow read: if true;
      allow write: if esEditor() && estaActivo();
    }

    match /votos/{doc} {
      allow read: if estaAutenticado();
      allow write: if estaAutenticado();
    }

    match /pagos_pendientes/{doc} {
      allow read: if estaAutenticado();
      allow create: if estaAutenticado();
      allow update: if esEditor() && estaActivo();
    }

    match /notificaciones/{doc} {
      allow read: if estaAutenticado();
      allow create: if estaAutenticado();
      allow update: if estaAutenticado();
    }
  }
}
